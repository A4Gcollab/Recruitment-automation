# A4G LinkedIn Recruitment Automation — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# Authoritative list: CONTRACTS.md §1. New versions add to the bottom.

# -----------------------------------------------------------------------------
# v0.1 — Foundation + Stage-1 Email
# -----------------------------------------------------------------------------

# PostgreSQL — local dev: WSL native postgres. Prod: Neon free tier.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/a4g_local

# NextAuth v5. Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Admin login. Hash: node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 10))"
# IMPORTANT: escape $ signs in the hash with \$ (e.g. \$2a\$10\$...)
ADMIN_EMAIL=admin@a4g.local
ADMIN_PASSWORD_HASH=

# Gmail SMTP — for sending all candidate emails (Stage-1, reminders, Stage-2)
# Setup: Gmail account → 2-Step Verification → App Passwords → generate 16-char code
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_SENDER_NAME=Omysha Foundation — HR Team

# Google Service Account — for Sheets API (applicant import, form polling, tracker sheet)
# Setup: Google Cloud Console → IAM → Service Accounts → create → JSON key → extract email + private key
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Email sending safety
SENDING_WINDOW_START_IST=9
SENDING_WINDOW_END_IST=18
HOURLY_SEND_CAP=20
SEND_DELAY_MIN_SECONDS=30
SEND_DELAY_MAX_SECONDS=60
KILL_SWITCH_EMAIL=false

# -----------------------------------------------------------------------------
# v0.3 — Reply Detection (add when v0.3 starts)
# -----------------------------------------------------------------------------
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
