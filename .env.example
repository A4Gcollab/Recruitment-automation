# A4G Recruitment Automation — environment variables
# Copy to .env.local and fill in the real values. Never commit .env.local.
# Authoritative list lives in CONTRACTS.md §1. New versions add to the bottom.

# -----------------------------------------------------------------------------
# v0.1 — Foundation
# -----------------------------------------------------------------------------

# Postgres connection string.
#  - Local dev:  start the Docker container with `docker compose up -d postgres`
#                and use the URL below (matches docker-compose.yml defaults).
#  - Production: paste the **pooled** URL from Neon dashboard → Connection details.
#                Production URL format is `postgres://USER:PASSWORD@HOST/DB?sslmode=require`.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/a4g_local

# NextAuth v5. Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Single admin user (v1). Hash with bcrypt: node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 10))"
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Google Service Account for Sheets API. Create in Google Cloud Console → IAM & Admin → Service Accounts.
# Share each source sheet with this email as "Viewer". See DEPLOYMENT.md.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the PEM private key including BEGIN/END lines. Keep literal \n or use real newlines inside quotes.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# v0.4 — Email subsystem (add when v0.4 starts)
# -----------------------------------------------------------------------------
# KILL_SWITCH_EMAIL=false
# RESEND_API_KEY=
# RESEND_WEBHOOK_SECRET=
# RESEND_FROM_EMAIL=
# SENDING_WINDOW_START_IST=9
# SENDING_WINDOW_END_IST=18
# DAILY_SEND_CAP=80
# SEND_DELAY_MIN_SECONDS=90
# SEND_DELAY_MAX_SECONDS=180

# -----------------------------------------------------------------------------
# v0.5 — Enrichment
# -----------------------------------------------------------------------------
# SNOV_API_USER_ID=
# SNOV_API_SECRET=
# APOLLO_API_KEY=

# -----------------------------------------------------------------------------
# v0.6 — Cron
# -----------------------------------------------------------------------------
# CRON_SECRET=

# -----------------------------------------------------------------------------
# v0.7 — Compliance
# -----------------------------------------------------------------------------
# ADMIN_ALERT_EMAIL=
